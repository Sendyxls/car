# Скопируйте этот файл в .env для локальной разработки
# На Railway все эти переменные задаются в разделе Variables

# Обязательно — замените на случайную строку 32+ символов
SECRET_KEY=замените-на-длинную-случайную-строку

# Путь к папке с данными (SQLite + uploads)
# Railway: укажите путь куда примонтирован Volume, например /data
# Локально: не указывать — будет папка проекта
DATA_DIR=/data

# Папка для загруженных фото
# Railway: /data/uploads
# Локально: не указывать — будет static/uploads/ в папке проекта
UPLOAD_FOLDER=/data/uploads
